---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import WhySection from '../components/WhySection.astro';
import ModulesSection from '../components/ModulesSection.astro';
import DifferentiatorsSection from '../components/DifferentiatorsSection.astro';
import ResultsSection from '../components/ResultsSection.astro';
import ContactSection from '../components/ContactSection.astro';
import Footer from '../components/Footer.astro';

const lang = 'en';

const modulesEntries = await getCollection('modules');
const modulesEntry = modulesEntries.find(e => e.id === 'en');
const modulesData = modulesEntry?.data ?? [];

const differentiatorsEntries = await getCollection('differentiators');
const differentiatorsEntry = differentiatorsEntries.find(e => e.id === 'en');
const differentiatorsData = differentiatorsEntry?.data ?? [];

const contactEntries = await getCollection('contact');
const contactEntry = contactEntries.find(e => e.id === 'en');
const contactData = contactEntry?.data ?? { name: '', phone: '', email: '', modalidades: [] };

const resultsEntries = await getCollection('results');
const resultsEntry = resultsEntries.find(e => e.id === 'en');
const resultsData = resultsEntry?.data ?? [];
---

<Layout lang={lang}>
  <Header lang={lang} />
  <Hero lang={lang} />
  <WhySection lang={lang} />
  <ModulesSection lang={lang} modules={modulesData} />
  <DifferentiatorsSection lang={lang} differentiators={differentiatorsData} />
  <ResultsSection lang={lang} results={resultsData} />
  <ContactSection lang={lang} contact={contactData} />
  <Footer lang={lang} contact={contactData} />
</Layout>