---
import { useTranslations } from "../i18n/ui";

interface Props {
  lang: "es" | "en";
  results: string[];
}

const { lang, results } = Astro.props;
const t = useTranslations(lang);
---

<section
  id="resultados"
  class="relative py-24 overflow-hidden bg-white dark:bg-neutral-950"
>
  <div class="absolute inset-0 bg-green-50/80 dark:bg-[#61b119]/10"></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8 w-full">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div class="order-2 lg:order-1">
        <span
          class="inline-block text-[#61b119] font-semibold tracking-widest text-sm uppercase mb-4"
        >
          {t.results.tag}
        </span>
        <h2
          class="text-4xl md:text-5xl font-bold text-neutral-900 dark:text-white mb-6"
        >
          {t.results.title}
        </h2>
        <p class="text-neutral-600 dark:text-neutral-300 text-lg mb-8">
          {t.results.description}
        </p>
        <div class="relative">
          <div class="absolute inset-0 bg-[#61b119]/30 rounded-xl blur-xl">
          </div>
          <img
            src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=600&q=80"
            alt={t.results.title}
            class="relative rounded-xl shadow-2xl shadow-[#61b119]/20"
          />
          <div
            class="absolute -bottom-4 -right-4 bg-[#61b119] text-white font-bold text-xl px-6 py-3 rounded-lg shadow-lg"
          >
            {t.results.efficiency}
          </div>
        </div>
      </div>

      <div class="order-1 lg:order-2 space-y-4">
        {
          results.map((result) => (
            <div class="flex items-center gap-4 p-5 bg-green-100/70 dark:bg-[#61b119]/10 border border-green-200 dark:border-[#61b119]/30 hover:border-[#61b119]/60 transition-all duration-300 rounded-xl">
              <div class="w-12 h-12 bg-[#61b119] flex items-center justify-center flex-shrink-0 rounded-lg shadow-lg shadow-[#61b119]/30">
                <svg
                  class="w-6 h-6 text-white"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M5 13l4 4L19 7"
                  />
                </svg>
              </div>
              <span class="text-neutral-900 dark:text-white font-medium">
                {result}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
