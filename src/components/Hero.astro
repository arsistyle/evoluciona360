---
import { useTranslations } from "../i18n/ui";
import Icon from "./Icon.astro";

interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const basePath = lang === "es" ? "" : `/${lang}`;
---

<header class="relative min-h-screen flex items-center overflow-hidden pt-20">
  <div class="absolute inset-0">
    <video
      autoplay
      muted
      loop
      playsinline
      class="w-full h-full object-cover"
      poster="https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=1920&q=80"
    >
      <source
        src="https://videos.pexels.com/video-files/6618330/6618330-uhd_2560_1440_24fps.mp4"
        type="video/mp4"
      />
    </video>
    <div
      class="absolute inset-0 bg-gradient-to-br from-white/90 via-white/70 to-white/50 dark:from-[#004d91]/60 dark:via-neutral-900/80 dark:to-neutral-900"
    >
    </div>
    <div
      class="absolute inset-0 bg-gradient-to-t from-white via-white/30 to-transparent dark:from-neutral-900 dark:via-neutral-900/50 dark:to-transparent"
    >
    </div>
  </div>

  <div class="absolute inset-0 opacity-[0.05] dark:opacity-[0.05]">
    <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
          <path
            d="M 60 0 L 0 0 0 60"
            fill="none"
            stroke="currentColor"
            stroke-width="1"></path>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)"></rect>
    </svg>
  </div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8 py-32 w-full">
    <div class="max-w-4xl">
      <div class="inline-flex items-center gap-3 mb-8 animate-fade-in-up">
        <div class="h-px w-12 bg-[#f89c1d]"></div>
        <span class="text-[#f89c1d] font-semibold tracking-widest uppercase">
          {t.hero.tagline}
        </span>
      </div>

      <h1
        class="text-5xl md:text-7xl lg:text-8xl font-extrabold tracking-tight mb-6 animate-fade-in-up animate-delay-100"
      >
        <span class="text-neutral-900 dark:text-white"
          >{t.hero.title.replace("360", "")}</span
        ><span class="text-[#61b119]">360</span>
      </h1>

      <p
        class="text-xl md:text-2xl text-neutral-700 dark:text-white font-medium mb-4 animate-fade-in-up animate-delay-200"
      >
        {t.hero.subtitle}
      </p>
      <p
        class="text-lg md:text-xl text-neutral-600 dark:text-neutral-300 mb-12 max-w-2xl animate-fade-in-up animate-delay-300"
      >
        {t.hero.description}
      </p>

      <div
        class="flex flex-col sm:flex-row gap-4 animate-fade-in-up animate-delay-400"
      >
        <a
          href={`${basePath}#contacto`}
          class="inline-flex items-center justify-center gap-2 bg-[#f89c1d] hover:bg-[#e08c0c] text-neutral-950 font-semibold text-base px-8 py-4 transition-all duration-300 hover:scale-105 shadow-lg shadow-[#f89c1d]/30 rounded-lg"
        >
          {t.hero.cta}
          <Icon name="arrow-right" size={20} />
        </a>
        <a
          href={`${basePath}#modulos`}
          class="inline-flex items-center justify-center gap-2 border-2 border-[#004d91] bg-[#004d91] hover:bg-[#003d7a] text-white font-semibold text-base px-8 py-4 transition-all duration-300 rounded-lg"
        >
          {t.hero.ctaSecondary}
        </a>
      </div>
    </div>

    <div
      class="grid grid-cols-2 md:grid-cols-4 gap-8 mt-20 pt-12 border-t border-neutral-300 dark:border-white/30 animate-fade-in-up animate-delay-400 text-center"
    >
      <div>
        <div class="text-4xl md:text-8xl font-bold text-[#61b119]">8</div>
        <div class="text-neutral-700 dark:text-white mt-1">
          {lang === "es" ? "Módulos Integrales" : "Integral Modules"}
        </div>
      </div>
      <div>
        <div class="text-4xl md:text-8xl font-bold text-[#004d91]">100%</div>
        <div class="text-neutral-700 dark:text-white mt-1">
          {t.hero.stats.auditable}
        </div>
      </div>
      <div>
        <div class="text-4xl md:text-8xl font-bold text-[#f89c1d]">0</div>
        <div class="text-neutral-700 dark:text-white mt-1">
          {t.hero.stats.burocracia}
        </div>
      </div>
      <div>
        <div
          class="text-4xl md:text-8xl font-bold text-neutral-900 dark:text-white"
        >
          360°
        </div>
        <div class="text-neutral-700 dark:text-white mt-1">
          {t.hero.stats.cobertura}
        </div>
      </div>
    </div>
  </div>
</header>
