---
import { useTranslations } from '../i18n/ui';

interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const painPoints = [
  { numero: '01', descripcion: t.why.painPoints['01'] },
  { numero: '02', descripcion: t.why.painPoints['02'] },
  { numero: '03', descripcion: t.why.painPoints['03'] },
  { numero: '04', descripcion: t.why.painPoints['04'] }
];
---

<section id="por-que" class="relative py-24 overflow-hidden">
  <div class="absolute inset-0">
    <img
      src="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=1920&q=80"
      alt="Análisis de negocios"
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-white/90 dark:bg-neutral-900/85"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8 w-full">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <span
          class="inline-block text-[#f89c1d] font-semibold tracking-widest text-sm uppercase mb-4"
        >
          {t.why.tag}
        </span>
        <h2
          class="text-4xl md:text-5xl font-bold text-neutral-900 dark:text-white mb-6"
        >
          {t.why.title}
        </h2>
        <p class="text-neutral-700 dark:text-neutral-300 text-lg">
          {t.why.description}
        </p>
      </div>
      <div class="space-y-4">
        {
          painPoints.map((point) => (
            <div class="flex items-start gap-4 p-6 bg-white/60 dark:bg-white/5 backdrop-blur-sm border-l-4 border-[#f89c1d] hover:bg-white/80 dark:hover:bg-white/10 transition-colors duration-300 rounded-r-lg shadow-sm">
              <span class="flex-shrink-0 w-8 h-8 bg-[#f89c1d] text-neutral-950 font-bold flex items-center justify-center rounded-lg">
                {point.numero}
              </span>
              <p class="text-neutral-800 dark:text-white font-medium">
                {point.descripcion}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>